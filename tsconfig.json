{
	"compilerOptions": {
		"target": "ES2021",
		"module": "Node16",
		"lib": ["es2021"],
		"moduleResolution": "node16",
		"strict": true,
		"esModuleInterop": true,
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"types": ["node"]
	}
}
