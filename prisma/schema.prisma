generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String           @id @default(uuid()) @db.Uuid
  email         String           @unique @db.VarChar(255)
  password_hash String           @db.VarChar(255)
  full_name     String           @db.VarChar(255)
  status        String           @db.VarChar(50)
  created_at    DateTime         @default(now())

  user_roles        UserRole[]
  orders            Order[]
  tickets_scanned   Ticket[]          @relation("TicketScannedBy")
  notification_logs NotificationLog[]
  background_jobs   BackgroundJob[]   @relation("BackgroundJobTriggeredBy")

  refresh_token     String?          @db.Text

  @@map("users")
}

model Role {
  id          String         @id @default(uuid()) @db.Uuid
  name        String         @unique @db.VarChar(100)
  description String?        @db.VarChar(255)

  user_roles       UserRole[]
  role_permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String          @id @default(uuid()) @db.Uuid
  code        String          @unique @db.VarChar(100)
  description String?         @db.VarChar(255)

  role_permissions RolePermission[]

  @@map("permissions")
}

model UserRole {
  user_id String @db.Uuid
  role_id String @db.Uuid

  user User @relation(fields: [user_id], references: [id])
  role Role @relation(fields: [role_id], references: [id])

  @@id([user_id, role_id])
  @@map("user_roles")
}

model RolePermission {
  role_id       String @db.Uuid
  permission_id String @db.Uuid

  role       Role       @relation(fields: [role_id], references: [id])
  permission Permission @relation(fields: [permission_id], references: [id])

  @@id([role_id, permission_id])
  @@map("role_permissions")
}

model Concert {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(255)
  description String?  @db.Text
  location    String   @db.VarChar(255)
  ai_bio      String?  @db.Text
  start_time  DateTime
  svg_map_url String?  @db.VarChar(500)
  status      String   @db.VarChar(50)

  ticket_categories TicketCategory[]
  orders            Order[]
  guest_lists       GuestList[]
  background_jobs   BackgroundJob[] @relation("BackgroundJobConcert")

  @@map("concerts")
}

model TicketCategory {
  id             String  @id @default(uuid()) @db.Uuid
  concert_id     String  @db.Uuid
  name           String  @db.VarChar(100)
  price          Decimal @db.Decimal(10, 2)
  total_quantity Int
  max_per_user   Int

  concert Concert @relation(fields: [concert_id], references: [id])
  tickets Ticket[]

  @@map("ticket_categories")
}

model Order {
  id           String   @id @default(uuid()) @db.Uuid
  user_id      String   @db.Uuid
  concert_id   String   @db.Uuid
  total_amount Decimal  @db.Decimal(10, 2)
  status       String   @db.VarChar(50)
  created_at   DateTime @default(now())
  expires_at   DateTime

  user                 User                 @relation(fields: [user_id], references: [id])
  concert              Concert              @relation(fields: [concert_id], references: [id])
  tickets              Ticket[]
  payment_transactions PaymentTransaction[]

  @@map("orders")
}

model Ticket {
  id           String   @id @default(uuid()) @db.Uuid
  order_id     String   @db.Uuid
  category_id  String   @db.Uuid
  qr_code_hash String   @unique @db.VarChar(255)
  is_scanned   Boolean  @default(false)
  scanned_at   DateTime?
  scanned_by   String?  @db.Uuid

  order           Order          @relation(fields: [order_id], references: [id], onDelete: Cascade)
  category        TicketCategory @relation(fields: [category_id], references: [id])
  scanned_by_user User?          @relation("TicketScannedBy", fields: [scanned_by], references: [id])

  @@map("tickets")
}

model PaymentTransaction {
  id                       String   @id @default(uuid()) @db.Uuid
  order_id                 String   @db.Uuid
  payment_method           String   @db.VarChar(50)
  transaction_id_3rd_party String?  @db.VarChar(255)
  amount                   Decimal  @db.Decimal(10, 2)
  status                   String   @db.VarChar(50)
  idempotency_key          String   @unique @db.VarChar(255)
  raw_response             Json?    @db.JsonB
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt

  order Order @relation(fields: [order_id], references: [id])

  @@map("payment_transactions")
}

model GuestList {
  id              String  @id @default(uuid()) @db.Uuid
  concert_id      String  @db.Uuid
  email           String  @db.VarChar(255)
  full_name       String  @db.VarChar(255)
  ticket_category String  @db.VarChar(100)
  is_scanned      Boolean @default(false)

  concert Concert @relation(fields: [concert_id], references: [id])

  @@unique([concert_id, email])
  @@map("guest_lists")
}

model BackgroundJob {
  id                 String   @id @default(uuid()) @db.Uuid
  trigger_by_user_id String   @db.Uuid
  job_type           String   @db.VarChar(100)
  target_id          String   @db.Uuid
  status             String   @db.VarChar(50)
  progress_percentage Int
  payload            Json?    @db.JsonB
  result_data        Json?    @db.JsonB
  error_message      String?  @db.Text
  created_at         DateTime @default(now())
  completed_at       DateTime?

  trigger_by_user User    @relation("BackgroundJobTriggeredBy", fields: [trigger_by_user_id], references: [id])
  concert         Concert @relation("BackgroundJobConcert", fields: [target_id], references: [id])

  @@map("background_jobs")
}

model NotificationTemplate {
  id      String @id @default(uuid()) @db.Uuid
  code    String @db.VarChar(100)
  channel String @db.VarChar(50)
  subject String @db.VarChar(255)
  content String @db.Text

  notification_logs NotificationLog[]

  @@map("notification_templates")
}

model NotificationLog {
  id            String   @id @default(uuid()) @db.Uuid
  user_id       String   @db.Uuid
  template_id   String   @db.Uuid
  target        String   @db.VarChar(255)
  status        String   @db.VarChar(50)
  error_message String?  @db.Text
  retry_count   Int
  created_at    DateTime @default(now())
  sent_at       DateTime?

  user     User                 @relation(fields: [user_id], references: [id])
  template NotificationTemplate @relation(fields: [template_id], references: [id])

  @@map("notification_logs")
}
