# Copy this file to .env.local and update values as needed

# Backend API URL (used by Next.js proxy route)
REMOTE_API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001

# API base for client requests (defaults to /api/proxy if unset)
NEXT_PUBLIC_API_BASE_URL=/api/proxy

# Frontend URL (backend uses this for email redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000
