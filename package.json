{
    "name": "ticket_box",
    "private": true,
    "workspaces": [
        "apps/*"
    ],
    "scripts": {
        "db:seed": "prisma db seed",
        "prisma:generate": "prisma generate",
        "prisma:validate": "prisma validate",
        "db:migrate:deploy": "prisma migrate deploy",
        "setup:hooks": "git config core.hooksPath .githooks",
        "verify:push": "npm run lint && npm run typecheck:api && npm run test:api:unit",
        "lint": "eslint \"apps/backend-api/src/**/*.ts\" \"prisma/**/*.ts\" \"prisma/seed.ts\" --cache --cache-location .cache/eslint",
        "typecheck:api": "tsc -p apps/backend-api/tsconfig.json --noEmit",
        "test:api:unit": "node --test --import tsx apps/backend-api/tests/**/*.unit.ts",
        "build:api": "tsc -p apps/backend-api/tsconfig.json",
        "build": "npm run build:api",
        "start:api": "ts-node --project apps/backend-api/tsconfig.json apps/backend-api/src/main.ts",
        "start:api:prod": "node apps/backend-api/dist/main.js"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@faker-js/faker": "^10.4.0",
        "@types/bcryptjs": "^2.4.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^22.13.5",
        "@types/nodemailer": "^8.0.0",
        "@types/swagger-ui-express": "^4.1.8",
        "@typescript-eslint/eslint-plugin": "^8.60.0",
        "@typescript-eslint/parser": "^8.60.0",
        "eslint": "^10.4.0",
        "globals": "^17.6.0",
        "jest-mock": "^30.4.1",
        "prisma": "^6.13.0",
        "ts-node": "^10.9.2",
        "tsx": "^4.19.2",
        "typescript": "^5.6.3"
    },
    "dependencies": {
        "@nestjs/common": "^11.1.24",
        "@nestjs/core": "^11.1.24",
        "@nestjs/platform-express": "^11.1.24",
        "@nestjs/swagger": "^11.0.1",
        "@prisma/client": "^6.13.0",
        "bcryptjs": "^2.4.3",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.15.1",
        "jsonwebtoken": "^9.0.3",
        "nodemailer": "^8.0.9",
        "redis": "^6.0.0",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.2",
        "swagger-ui-express": "^5.0.1"
    },
    "prisma": {
        "seed": "tsx prisma/seed.ts"
    }
}